        "Facture opérateur télécom",
        "Taxe foncière (avis séparé de taxe habitation)"
      ]
    },
    "EMPLOI": {
      "groups": 8,
      "certaintyTokens": ["extrait kbis"],
      "edgeCasesHandled": [
        "CDI/CDD forme longue vs courte",
        "Contrat d'apprentissage",
        "Contrat de professionnalisation",
        "Attestation certifiant emploi"
      ]
    },
    "BANCAIRE": {
      "groups": 4,
      "certaintyTokens": [],
      "proximityWindows": "3000–5000 chars"
