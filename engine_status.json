  "forensics": {
    "pdfMetadata": {
      "suspectProducers": [
        "canva", "photoshop", "illustrator", "ilovepdf",
        "wondershare", "sejda", "smallpdf", "snagit",
        "paint.net", "pdfzorro", "pdfescape", "pdf24", "web2pdf"
      ],
      "method": "Read first 10 KB of PDF as Latin-1, regex-search /Producer and /Creator fields",
      "penaltyOnSuspect": -20
    },
    "luhnSiret": {
      "enabled": true,
      "appliesTo": ["BULLETIN"],
      "penaltyOnInvalid": -18
    },
    "salaryRatio": {
      "normalRange": [0.65, 0.95],
      "highSeverityRange": [0.0, 0.50],
      "appliesTo": ["BULLETIN"]
    },
    "qr2DDoc": {
      "appliesTo": ["REVENUS_FISCAUX"],
      "missingQrPenalty": -7
    }
  },

  "confidenceLevels": {
    "certain":      { "range": [100, 100], "action": "auto-accept",      "ui": "Certifié (marqueur machine)" },
    "high":         { "range": [70, 99],   "action": "auto-accept",      "ui": "Vérifié (vert)" },
    "needsConfirm": { "range": [40, 69],   "action": "ask-user",         "ui": "Nous avons détecté un [Type], est-ce correct ?" },
    "low":          { "range": [1, 39],    "action": "unknown-flow",     "ui": "Document non reconnu (gris)" },
    "unknown":      { "range": [0, 0],     "action": "unknown-flow",     "ui": "Document vide ou illisible" }
  },

