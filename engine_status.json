    "IDENTITE": {
      "groups": 9,
      "certaintyTokens": ["<<<<<<<<<<<<<<<", "idfra", "idfrax", "idfrx", "p<fra", "p<<fra", "titre de séjour", "carte de résident"],
      "edgeCasesHandled": [
        "CNI nouvelle génération (sexe + carte)",
