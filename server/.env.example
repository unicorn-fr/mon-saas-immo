# ─── APPLICATION ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
API_VERSION=v1

# ─── MODE LANCEMENT ───────────────────────────────────────────────────────────
# waitlist = inscriptions bloquées (pre-launch)
# live     = tout ouvert (changer le jour J)
LAUNCH_MODE=waitlist

# Secret admin pour bypasser le blocage (header x-admin-secret ou URL ?secret=)
ADMIN_SECRET=BAILIO_ADMIN_2024

# Emails autorisés à s'inscrire même en mode waitlist (comma-separated)
ADMIN_EMAILS=votre@email.com,autre@email.com

# URL publique du frontend (CORS + liens email)
FRONTEND_URL=https://bailio.vercel.app
CORS_ORIGIN=https://bailio.vercel.app

# URL publique du backend (pour les URLs absolues si Cloudinary non configuré)
SERVER_URL=https://votre-app.railway.app

# ─── BASE DE DONNÉES ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/bailio

# ─── REDIS (Upstash — copier depuis le dashboard Upstash) ────────────────────
REDIS_URL=rediss://default:token@host.upstash.io:6379

# ─── AUTH / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_minimum_32_characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_secret_minimum_32_characters
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── CLOUDINARY (stockage persistant — remplace le disque local) ──────────────
# Option 1 — URL complète (recommandé)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# Option 2 — Variables séparées
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ─── EMAILS (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_resend_api_key
EMAIL_FROM=noreply@bailio.fr

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── SÉCURITÉ ─────────────────────────────────────────────────────────────────
TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_key

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── FIREBASE (optionnel — notifications push) ────────────────────────────────
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── STRIPE (abonnements et paiements) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_EXPERT_MONTHLY_PRICE_ID=price_...
STRIPE_EXPERT_ANNUAL_PRICE_ID=price_...

# ─── SUPPRIMÉ — plus nécessaire avec Cloudinary ───────────────────────────────
# UPLOAD_DIR=./uploads  ← disque local non requis en production
