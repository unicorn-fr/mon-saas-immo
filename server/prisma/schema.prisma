// Prisma Schema for Plateforme Gestion Locative

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  TENANT        // Locataire
  OWNER         // Propriétaire
  ADMIN         // Admin plateforme
  SUPER_ADMIN   // Super Admin — accès total plateforme
}

enum PropertyType {
  APARTMENT   // Appartement
  HOUSE       // Maison
  STUDIO      // Studio
  DUPLEX      // Duplex
  LOFT        // Loft
}

enum PropertyStatus {
  AVAILABLE       // Disponible — approuvé par admin, visible aux locataires
  OCCUPIED        // Occupé — en location active
  RESERVED        // Réservé
  DRAFT           // Brouillon — non soumis
  PENDING_REVIEW  // En attente de vérification par un administrateur
}

enum BookingStatus {
  PENDING     // En attente
  CONFIRMED   // Confirmée
  CANCELLED   // Annulée
  COMPLETED   // Terminée
}

enum ContractStatus {
  DRAFT           // Brouillon
  SENT            // Envoyé au locataire
  SIGNED_OWNER    // Signé par le propriétaire
  SIGNED_TENANT   // Signé par le locataire
  COMPLETED       // Signé par les deux parties
  ACTIVE          // Actif (en cours)
  EXPIRED         // Expiré
  TERMINATED      // Résilié
  CANCELLED       // Annulé
}

enum DateOverrideType {
  BLOCKED     // Bloquer une date (aucune visite)
  EXTRA       // Ajouter une dispo exceptionnelle
}

enum ApplicationStatus {
  PENDING     // En attente de décision du propriétaire
  APPROVED    // Approuvée — accès aux créneaux de visite débloqué
  REJECTED    // Refusée
  WITHDRAWN   // Retirée par le locataire
}

enum EdlSessionStatus {
  WAITING     // Créée, en attente que le locataire rejoigne
  ACTIVE      // Les deux parties sont connectées
  COMPLETED   // EDL finalisé et signé
}

enum TokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
  MAGIC_LINK
}

// ============================================
// MODELS
// ============================================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String?   // bcrypt hashed, nullable for OAuth-only users
  googleId          String?   @unique
  role              UserRole  @default(TENANT)

  // Personal Information
  firstName         String
  lastName          String
  phone             String?
  avatar            String?
  bio               String?   @db.Text

  // Identity document data (extracted by AI scanner)
  birthDate         String?   // date de naissance (DD/MM/YY)
  birthCity         String?   // ville de naissance
  nationality       String?   // nationalité (code 3 lettres, ex: "FRA")
  nationalNumber    String?   // n° de sécu (masqué)
  documentNumber    String?   // numéro CNI / passeport / titre de séjour
  documentExpiry    String?   // date de validité du document

  // Flexible AI-extracted metadata from all scanned documents (JSON)
  profileMeta       Json?     // { IDENTITE: {...}, BULLETIN: {...}, REVENUS_FISCAUX: {...}, ... }

  // Verification
  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  phoneVerified     Boolean   @default(false)
  phoneVerifiedAt   DateTime?

  // Dossier locataire — score calculé à chaque upload de document
  tenantScore       Int?      // score global du dossier (0-100)
  tenantScoreAt     DateTime? // dernière mise à jour du score

  // Trust & Anti-Fraud
  trustScore        Int       @default(50)   // 0-100 : calculé dynamiquement
  isVerifiedOwner   Boolean   @default(false) // Vérifié manuellement par admin (badge premium)
  reportCount       Int       @default(0)    // Nombre de signalements reçus
  isBanned          Boolean   @default(false) // Banni suite à fraude confirmée

  // 2FA — TOTP (Google Authenticator / Authy)
  totpSecret        String?
  totpEnabled       Boolean   @default(false)

  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?

  // Relations
  ownedProperties       Property[]            @relation("PropertyOwner")
  bookings              Booking[]             @relation("BookingTenant")
  sentMessages          Message[]             @relation("MessageSender")
  receivedMessages      Message[]             @relation("MessageReceiver")
  tenantContracts       Contract[]            @relation("ContractTenant")
  ownerContracts        Contract[]            @relation("ContractOwner")
  favorites             Favorite[]
  notifications         Notification[]
  refreshTokens         RefreshToken[]
  conversationsUser1    Conversation[]        @relation("ConversationUser1")
  conversationsUser2    Conversation[]        @relation("ConversationUser2")
  verificationTokens    VerificationToken[]
  uploadedDocuments     ContractDocument[]    @relation("DocumentUploader")
  tenantDocuments       TenantDocument[]
  applications          Application[]
  dossierSharesGranted  DossierShare[]        @relation("ShareGrantedBy")
  dossierSharesReceived DossierShare[]        @relation("ShareReceivedBy")
  fraudReportsFiled     FraudReport[]         @relation("FraudReporter")
  fraudReportsReceived  FraudReport[]         @relation("FraudTarget")
  subscription          Subscription?
  calendarInvitesSent   CalendarInvite[]      @relation("CalendarInviteSender")
  calendarInvitesReceived CalendarInvite[]    @relation("CalendarInviteReceiver")
  edlSessionsOwned      EdlSession[]          @relation("EdlSessionOwner")
  edlSessionsJoined     EdlSession[]          @relation("EdlSessionTenant")
  expenses              Expense[]             @relation("OwnerExpenses")
  loans                 Loan[]                @relation("OwnerLoans")
  ownedMaintenanceReqs  MaintenanceRequest[]  @relation("OwnerMaintenanceRequests")
  tenantMaintenanceReqs MaintenanceRequest[]  @relation("TenantMaintenanceRequests")

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model VerificationToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TokenType
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@map("verification_tokens")
}

model Property {
  id            String         @id @default(uuid())
  ownerId       String
  owner         User           @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // Basic Information
  title         String
  description   String         @db.Text
  type          PropertyType
  status        PropertyStatus @default(DRAFT)

  // Location
  address       String
  city          String
  postalCode    String
  country       String         @default("France")
  latitude      Float?
  longitude     Float?

  // Characteristics
  bedrooms      Int
  bathrooms     Int
  surface       Float          // m²
  floor         Int?
  totalFloors   Int?
  furnished     Boolean        @default(false)

  // Financial
  price         Float          // Monthly rent
  charges       Float?         // Charges
  deposit       Float?         // Security deposit

  // Media
  images        String[]       // Array of image URLs
  virtualTour   String?        // 360° tour URL

  // Amenities
  hasParking    Boolean        @default(false)
  hasBalcony    Boolean        @default(false)
  hasElevator   Boolean        @default(false)
  hasGarden     Boolean        @default(false)
  amenities     String[]       // ["wifi", "dishwasher", "ac", ...]

  // Availability
  availableFrom DateTime?
  visitDuration Int            @default(30) // Duration of visit slots in minutes

  // Owner Verification Documents (required to publish)
  ownerIdDocument       String?  // URL to owner ID document (CNI/Passport)
  propertyProofDocument String?  // URL to property proof (titre de propriete/taxe fonciere)

  // Admin review
  reviewNote            String?  // Admin note (rejection reason or approval comment)

  // Selection Criteria (JSON) — owner's pre-qualification requirements
  // { minSalaryRatio, requiredGuarantor, acceptedGuarantorTypes, requiredDocCategories,
  //   preferredContractTypes, autoPilot, minScore }
  selectionCriteria Json?

  // Statistics
  views         Int            @default(0)
  contactCount  Int            @default(0)

  // Timestamps
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  publishedAt   DateTime?

  // Relations
  bookings               Booking[]
  conversations          Conversation[] @relation("ConversationProperty")
  favorites              Favorite[]
  contracts              Contract[]
  visitAvailabilitySlots VisitAvailabilitySlot[]
  visitDateOverrides     VisitDateOverride[]
  applications           Application[]
  calendarInvites        CalendarInvite[]
  expenses               Expense[]
  loan                   Loan?
  maintenanceRequests    MaintenanceRequest[]

  @@index([ownerId])
  @@index([city])
  @@index([status])
  @@index([type])
  @@index([price])
  @@index([createdAt])
  @@index([ownerId, status])     // Dashboard propriétaire
  @@index([city, status])        // Recherche par ville
  @@index([status, createdAt])   // Listing public trié
  @@map("properties")
}

model Booking {
  id          String        @id @default(uuid())
  propertyId  String
  property    Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  tenantId    String
  tenant      User          @relation("BookingTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  // Visit Details
  visitDate   DateTime      // Date of the visit
  visitTime   String        // Time slot (e.g., "14:00")
  duration    Int           @default(30) // Duration in minutes

  status      BookingStatus @default(PENDING)

  // Notes
  tenantNotes String?       @db.Text
  ownerNotes  String?       @db.Text

  // Status tracking
  confirmedAt         DateTime?
  cancelledAt         DateTime?
  cancellationReason  String?   @db.Text

  // Timestamps
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([propertyId])
  @@index([tenantId])
  @@index([visitDate])
  @@index([status])
  @@index([createdAt])
  @@map("bookings")
}

model Conversation {
  id            String    @id @default(uuid())

  // Participants (always 2 users in a conversation)
  user1Id       String
  user1         User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)

  user2Id       String
  user2         User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  // Last message info (denormalized for performance)
  lastMessageAt     DateTime?
  lastMessageText   String?   @db.Text

  // Unread counts
  unreadCountUser1  Int       @default(0)
  unreadCountUser2  Int       @default(0)

  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Optional property context (set when conversation starts from a property/application)
  propertyId    String?
  property      Property? @relation("ConversationProperty", fields: [propertyId], references: [id], onDelete: SetNull)

  // Relations
  messages      Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([lastMessageAt])
  @@index([propertyId])
  @@map("conversations")
}

model Message {
  id              String       @id @default(uuid())

  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId        String
  sender          User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId      String
  receiver        User         @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  // Content
  content         String       @db.Text
  attachments     String[]     // Array of file URLs

  // Read status
  isRead          Boolean      @default(false)
  readAt          DateTime?

  // Timestamps
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([isRead])
  @@index([createdAt])
  @@index([conversationId, createdAt])  // Chargement conversation
  @@map("messages")
}

model Contract {
  id          String         @id @default(uuid())

  propertyId  String
  property    Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  tenantId    String
  tenant      User           @relation("ContractTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  ownerId     String
  owner       User           @relation("ContractOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  status      ContractStatus @default(DRAFT)

  // Contract Details
  startDate   DateTime
  endDate     DateTime

  // Financial Terms
  monthlyRent Float
  charges     Float?
  deposit     Float?

  // Structured Content (wizard form data as JSON)
  content         Json?         // Full form data from wizard steps
  customClauses   Json?         // Array of custom clauses [{title, description, enabled}]

  // Documents
  pdfUrl          String?

  // Signatures
  ownerSignature  String?       @db.Text  // Base64 signature image
  tenantSignature String?       @db.Text  // Base64 signature image
  signedByOwner   DateTime?
  signedByTenant  DateTime?
  signedAt        DateTime?               // When both parties have signed

  // Additional Terms
  terms           String?       @db.Text

  // Timestamps
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  documents        ContractDocument[]
  payments         Payment[]
  edlSession       EdlSession?
  paymentSettings  PaymentSettings?

  @@index([propertyId])
  @@index([tenantId])
  @@index([ownerId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@map("contracts")
}

enum DocumentStatus {
  PENDING
  UPLOADED
  VALIDATED
  REJECTED
}

model ContractDocument {
  id            String         @id @default(uuid())

  contractId    String
  contract      Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)

  uploadedById  String
  uploadedBy    User           @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  // Document info
  category      String         // DDT_DPE, IDENTITE_LOCATAIRE, etc.
  status        DocumentStatus @default(UPLOADED)
  fileName      String
  fileUrl       String
  fileSize      Int
  mimeType      String

  // Validation
  rejectionReason String?      @db.Text

  // Auto-import from dossier
  fromDossier   Boolean        @default(false)

  // Timestamps
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([contractId])
  @@index([uploadedById])
  @@index([category])
  @@map("contract_documents")
}

model TenantDocument {
  id         String         @id @default(uuid())

  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Document classification
  category   String         // IDENTITE | SITUATION_PRO | REVENUS | HISTORIQUE | GARANTIES
  docType    String         // e.g. CNI, PASSEPORT, CONTRAT_TRAVAIL, etc.
  status     DocumentStatus @default(UPLOADED)

  // File info
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String

  // Optional note / rejection reason
  note       String?        @db.Text

  // Auto-deletion — null = no expiry, set at upload
  expiresAt  DateTime?

  // Timestamps
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([userId])
  @@index([category])
  @@index([expiresAt])
  @@map("tenant_documents")
}

// Tracks every time an owner views a tenant's dossier — visible to the tenant
model DossierAccessLog {
  id          String   @id @default(uuid())

  tenantId    String   // whose dossier was accessed
  viewerId    String   // owner who accessed
  viewerName  String   // snapshot of owner name at time of access
  viewerEmail String   // snapshot of owner email

  // Context (optional — from which application/conversation)
  propertyId    String?
  propertyTitle String?

  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([viewerId])
  @@index([createdAt])
  @@map("dossier_access_logs")
}

model Favorite {
  id          String   @id @default(uuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
  @@map("favorites")
}

model Notification {
  id        String   @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Notification Details
  type      String   // "booking_created", "message_received", "payment_received", etc.
  title     String
  message   String   @db.Text

  // Read status
  isRead    Boolean  @default(false)
  readAt    DateTime?

  // Metadata (JSON for flexible data)
  metadata  Json?

  // Action link
  actionUrl String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model VisitAvailabilitySlot {
  id          String   @id @default(uuid())

  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  dayOfWeek   Int      // 0 = Dimanche, 1 = Lundi, ..., 6 = Samedi
  startTime   String   // "09:00"
  endTime     String   // "18:00"

  createdAt   DateTime @default(now())

  @@index([propertyId])
  @@map("visit_availability_slots")
}

model VisitDateOverride {
  id          String           @id @default(uuid())

  propertyId  String
  property    Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  date        DateTime         // Date spécifique
  type        DateOverrideType // BLOCKED ou EXTRA

  startTime   String?          // Requis si type = EXTRA
  endTime     String?          // Requis si type = EXTRA

  createdAt   DateTime         @default(now())

  @@index([propertyId])
  @@index([date])
  @@map("visit_date_overrides")
}

// Invitation propriétaire → locataire pour accéder au calendrier de visite
model CalendarInvite {
  id          String   @id @default(uuid())

  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  ownerId     String
  owner       User     @relation("CalendarInviteSender", fields: [ownerId], references: [id], onDelete: Cascade)

  tenantId    String
  tenant      User     @relation("CalendarInviteReceiver", fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([propertyId, tenantId])
  @@index([tenantId])
  @@index([ownerId])
  @@map("calendar_invites")
}

model Application {
  id            String            @id @default(uuid())

  propertyId    String
  property      Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  tenantId      String
  tenant        User              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  status        ApplicationStatus @default(PENDING)

  // Matching score (0–100) computed at submission time
  score         Int               @default(0)
  matchDetails  Json?             // { salary: {...}, guarantor: {...}, documents: {...}, contractType: {...} }

  // Tenant's cover letter / message
  coverLetter   String?           @db.Text

  // Guarantor info supplied by tenant
  hasGuarantor    Boolean         @default(false)
  guarantorType   String?         // "physique" | "visale"

  // Timestamps
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Each tenant can only have one active application per property
  @@unique([propertyId, tenantId])
  @@index([propertyId])
  @@index([tenantId])
  @@index([status])
  @@index([score])
  @@index([propertyId, status])  // CRM candidatures
  @@index([tenantId, status])    // Dashboard locataire
  @@index([createdAt])           // Tri par date
  @@map("applications")
}

// ============================================
// SÉCURITÉ — PARTAGE CONTRÔLÉ DU DOSSIER
// ============================================

// Le locataire accorde explicitement à un propriétaire un accès temporaire à son dossier.
// Sans entrée active ici, aucun propriétaire ne peut voir le dossier.
model DossierShare {
  id          String    @id @default(uuid())

  tenantId    String    // Le locataire qui accorde l'accès
  tenant      User      @relation("ShareGrantedBy", fields: [tenantId], references: [id], onDelete: Cascade)

  ownerId     String    // Le propriétaire qui reçoit l'accès
  owner       User      @relation("ShareReceivedBy", fields: [ownerId], references: [id], onDelete: Cascade)

  propertyId  String?   // Contexte facultatif (annonce liée)

  expiresAt   DateTime  // Accès limité dans le temps (défaut: 7 jours)
  revokedAt   DateTime? // Mis à jour si le locataire révoque manuellement

  createdAt   DateTime  @default(now())

  @@unique([tenantId, ownerId])
  @@index([tenantId])
  @@index([ownerId])
  @@index([expiresAt])
  @@map("dossier_shares")
}

// Signalement d'un utilisateur suspicieux
model FraudReport {
  id          String    @id @default(uuid())

  reporterId  String    // Qui signale
  reporter    User      @relation("FraudReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  targetId    String    // Qui est signalé
  target      User      @relation("FraudTarget", fields: [targetId], references: [id], onDelete: Cascade)

  reason      String    // FAKE_LISTING | DATA_THEFT | FAKE_DOCUMENTS | HARASSMENT | OTHER
  details     String?   @db.Text

  status      String    @default("PENDING")   // PENDING | REVIEWED | DISMISSED | ACTIONED
  reviewNote  String?   @db.Text
  reviewedAt  DateTime?
  reviewedBy  String?   // id du super-admin

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([reporterId])
  @@index([targetId])
  @@index([status])
  @@map("fraud_reports")
}

// ============================================
// SUPER ADMIN — AUDIT LOGS
// ============================================

model AuditLog {
  id          String   @id @default(uuid())

  // Who did the action
  actorId     String?              // null if system action
  actorEmail  String?

  // What they did
  action      String               // e.g. "DELETE_USER", "UPDATE_ROLE", "VIEW_MESSAGES"
  resource    String               // e.g. "User", "Contract", "TenantDocument"
  resourceId  String?              // ID of the affected resource

  // Details
  metadata    Json?                // { before: {...}, after: {...}, ip, userAgent, ... }
  severity    String  @default("INFO")  // INFO | WARNING | CRITICAL

  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@index([severity])
  @@map("audit_logs")
}

// ============================================
// ABONNEMENTS STRIPE
// ============================================

enum PlanType {
  FREE
  PRO
  EXPERT
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

model Subscription {
  id                   String       @id @default(cuid())
  userId               String       @unique
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String       @unique
  stripeSubscriptionId String?      @unique
  plan                 PlanType     @default(FREE)
  billingCycle         BillingCycle @default(MONTHLY)
  status               SubStatus    @default(ACTIVE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean      @default(false)
  trialEndsAt          DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

// ============================================
// PAIEMENTS DE LOYER + QUITTANCES
// ============================================

enum PaymentStatus {
  PENDING   // loyer attendu, non payé
  PAID      // payé, quittance générée
  LATE      // en retard (dueDate dépassée)
  WAIVED    // exonéré
}

model Payment {
  id                  String        @id @default(cuid())
  contractId          String
  contract            Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  amount              Float         // loyer en euros
  charges             Float         @default(0)
  dueDate             DateTime      // date d'échéance
  paidDate            DateTime?     // null = non payé
  status              PaymentStatus @default(PENDING)
  month               Int           // 1-12
  year                Int
  receiptCloudinaryId String?       // public_id Cloudinary du PDF quittance
  notes               String?       @db.Text
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([contractId, month, year])
  @@index([contractId, status])
  @@index([dueDate, status])
  @@map("payments")
}

// ============================================
// PARAMÈTRES QUITTANCES (par contrat)
// ============================================

model PaymentSettings {
  id          String   @id @default(cuid())
  contractId  String   @unique
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  dayOfMonth  Int      @default(5)    // Jour du mois pour la génération (1-28)
  autoSend    Boolean  @default(true) // Envoyer automatiquement au locataire
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("payment_settings")
}

// ============================================
// EDL SESSION (État des Lieux Synchrone)
// ============================================

model EdlSession {
  id          String           @id @default(cuid())
  contractId  String           @unique
  contract    Contract         @relation(fields: [contractId], references: [id], onDelete: Cascade)

  pin         String           // Code PIN 6 chiffres
  ownerId     String
  owner       User             @relation("EdlSessionOwner", fields: [ownerId], references: [id])
  tenantId    String?          // Défini quand le locataire rejoint
  tenant      User?            @relation("EdlSessionTenant", fields: [tenantId], references: [id])

  status      EdlSessionStatus @default(WAITING)
  edlType     String           @default("ENTREE") // ENTREE | SORTIE
  data        Json             @default("{}") // État complet de l'EDL (pièces, éléments, photos)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([pin])
  @@index([ownerId])
  @@map("edl_sessions")
}

// ============================================
// WAITLIST
// ============================================

model WaitlistEntry {
  id            String    @id @default(cuid())
  email         String    @unique
  firstName     String?
  position      Int
  isEarlyAccess Boolean   @default(false)
  notifiedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("waitlist_entries")
}

// ============================================
// FINANCES PROPRIÉTAIRE — DÉPENSES & PRÊT
// ============================================

enum ExpenseCategory {
  TAXE_FONCIERE
  ASSURANCE
  TRAVAUX
  CHARGES_COPRO
  AUTRE
}

enum MaintenanceCategory {
  PLOMBERIE
  ELECTRICITE
  CHAUFFAGE
  SERRURERIE
  AUTRE
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Expense {
  id          String          @id @default(cuid())
  propertyId  String
  ownerId     String
  category    ExpenseCategory
  description String
  amount      Float
  date        DateTime
  receiptUrl  String?

  property    Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  owner       User            @relation("OwnerExpenses", fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([ownerId])
  @@index([propertyId])
  @@index([date])
  @@index([ownerId, date])
  @@map("expenses")
}

model Loan {
  id             String   @id @default(cuid())
  propertyId     String   @unique
  ownerId        String
  bankName       String?
  totalAmount    Float
  monthlyPayment Float
  interestRate   Float
  durationMonths Int
  startDate      DateTime

  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  owner          User     @relation("OwnerLoans", fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ownerId])
  @@map("loans")
}

// ============================================
// MAINTENANCE — SIGNALEMENTS & INTERVENTIONS
// ============================================

model MaintenanceRequest {
  id          String              @id @default(cuid())
  propertyId  String
  ownerId     String
  tenantId    String?
  title       String
  description String              @db.Text
  category    MaintenanceCategory
  priority    MaintenancePriority @default(MEDIUM)
  status      MaintenanceStatus   @default(OPEN)
  aiAnalysis  Json?

  property    Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  owner       User                @relation("OwnerMaintenanceRequests", fields: [ownerId], references: [id], onDelete: Cascade)
  tenant      User?               @relation("TenantMaintenanceRequests", fields: [tenantId], references: [id], onDelete: SetNull)

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([ownerId])
  @@index([propertyId])
  @@index([status])
  @@index([priority])
  @@index([ownerId, status])
  @@map("maintenance_requests")
}
