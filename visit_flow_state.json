{
  "version": "1.0",
  "lastUpdated": "2026-03-01",
  "status": "COMPLETE",
  "selectionCriteria": {
    "schema": {
      "minSalaryRatio": "number (e.g. 3 = 3x rent)",
      "requiredGuarantor": "boolean",
      "acceptedGuarantorTypes": [
        "physique",
        "visale"
      ],
      "requiredDocCategories": [
        "IDENTITE",
        "REVENUS",
        "SITUATION_PRO",
        "HISTORIQUE",
        "GARANTIES"
      ],
      "preferredContractTypes": [
        "CDI",
        "CDD",
        "Alternance",
        "Intérim",
        "Indépendant",
        "Retraite"
      ],
      "autoPilot": "boolean - auto-approve matching candidates",
      "minScore": "number 0-100"
    },
    "storedAs": "Json? on Property model"
  },
  "matchingAlgorithm": {
    "salaryWeight": 40,
    "guarantorWeight": 30,
    "documentsWeight": 20,
    "contractTypeWeight": 10,
    "thresholds": {
      "ELIGIBLE": 70,
      "PARTIAL": 40,
      "INELIGIBLE": 0
    },
    "dataSources": {
      "salary": "user.profileMeta._composed.netSalary",
      "contractType": "user.profileMeta._composed.contractType",
      "employerName": "user.profileMeta._composed.employerName",
      "documents": "TenantDocument[] categories present",
      "guarantor": "Application.hasGuarantor + guarantorType"
    }
  },
  "applicationModel": {
    "status": [
      "PENDING",
      "APPROVED",
      "REJECTED",
      "WITHDRAWN"
    ],
    "fields": [
      "propertyId",
      "tenantId",
      "status",
      "score",
      "matchDetails",
      "coverLetter",
      "hasGuarantor",
      "guarantorType"
    ],
    "unique": "propertyId + tenantId"
  },
  "completedSteps": [
    "prisma schema: add selectionCriteria + Application model + enum",
    "prisma db push",
    "server: application.service.ts",
    "server: application.controller.ts",
    "server: application.routes.ts",
    "server: app.ts register routes",
    "client: application.types.ts",
    "client: application.service.ts",
    "client: matchingEngine.ts",
    "client: SelectionCriteriaForm component",
    "client: PreQualificationModal component",
    "client: ApplicationManagement page (owner)",
    "client: MyApplications page (tenant)",
    "client: PropertyDetailsPublic - add Postuler button",
    "client: CreateProperty - add criteria section",
    "client: EditProperty - add criteria section",
    "client: App.tsx - add routes"
  ],
  "pendingSteps": [],
  "routes": {
    "backend": {
      "POST /api/v1/applications": "tenant submits application",
      "GET /api/v1/applications": "list (owner sees for their properties, tenant sees own)",
      "GET /api/v1/applications/:id": "get one",
      "PATCH /api/v1/applications/:id/status": "owner approves/rejects",
      "DELETE /api/v1/applications/:id": "tenant withdraws",
      "GET /api/v1/applications/property/:propertyId": "owner views all candidates for a property",
      "GET /api/v1/applications/prequalify/:propertyId": "tenant checks eligibility live"
    },
    "frontend": {
      "/applications/manage": "owner: all applications across properties",
      "/applications/my": "tenant: my applications",
      "/properties/:id/applications": "owner: candidates for specific property"
    }
  }
}