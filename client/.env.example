# ─── BACKEND URL ─────────────────────────────────────────────────────────────
# Développement local
VITE_API_URL=http://localhost:5000/api/v1

# Production Railway — décommenter et remplacer
# VITE_API_URL=https://votre-app.railway.app/api/v1

# URL de base du backend (sans /api/v1) — fallback pour fichiers non Cloudinary
# VITE_API_BASE_URL=https://votre-app.railway.app

# ─── APP ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Bailio

# ─── MODE LANCEMENT ───────────────────────────────────────────────────────────
# waitlist = /register bloqué, redirige vers /
# live     = tout ouvert (changer le jour J)
VITE_LAUNCH_MODE=waitlist

# Même valeur que ADMIN_SECRET côté serveur
# Accès : https://bailio.fr/register?secret=BAILIO_ADMIN_2024
VITE_ADMIN_SECRET=BAILIO_ADMIN_2024

# ─── STRIPE (clé publique — décommenter si Stripe.js intégré côté client) ────
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── OPTIONNEL ────────────────────────────────────────────────────────────────
# VITE_MAPBOX_TOKEN=your_mapbox_token_here
